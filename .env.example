# Copy this file to .env.local for local development.
# In Vercel, set each variable per scope (Production / Preview / Development)
# via Project Settings -> Environment Variables.
# NEXT_PUBLIC_* values are safe to leak (chain IDs, public RPC URLs, WalletConnect project ID).
# Never prefix secret/server-only values (RPC keys, AI keys, HF tokens) with NEXT_PUBLIC_.

NEXT_PUBLIC_RPC_CELO_PRIMARY=https://forno.celo.org
NEXT_PUBLIC_RPC_ETH_PRIMARY=https://ethereum.publicnode.com
NEXT_PUBLIC_RPC_BASE_PRIMARY=https://mainnet.base.org
NEXT_PUBLIC_RPC_ARB_PRIMARY=https://arb1.arbitrum.io/rpc
NEXT_PUBLIC_RPC_OP_PRIMARY=https://mainnet.optimism.io
NEXT_PUBLIC_WALLETCONNECT_ID=your_walletconnect_project_id_here
NEXT_PUBLIC_APP_URL=http://localhost:3000
